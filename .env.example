# ─── Database ───────────────────────────────────────────────────────────
# SQLite path (relative to project root). Prisma reads this automatically.
DATABASE_URL=file:./db/custom.db

# ─── LLM providers (set at least one) ───────────────────────────────────
# When two or more are set, the scheduler rotates evenly across them
# (override with LLM_ROTATE=false to always use the first one).
#
# Provider order: zai → groq → gemini → anthropic
#
# Each provider has an optional _MODEL var to override the default model.
# Defaults:  ZAI=glm-4.6 · GROQ=llama-3.3-70b-versatile ·
#            GEMINI=gemini-2.5-flash · ANTHROPIC=claude-haiku-4.5

# Z.AI (GLM-4.6) — https://z.ai
ZAI_API_KEY=
ZAI_MODEL=glm-4.6

# Groq (Llama 3.3 70B) — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (2.5 Flash) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (Haiku 4.5) — https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4.5

# Rotate evenly across all configured providers? (default: true when ≥2 set)
LLM_ROTATE=true

# ─── YouTube OAuth ──────────────────────────────────────────────────────
# 1. Create a Google Cloud project: https://console.cloud.google.com/
# 2. Enable "YouTube Data API v3".
# 3. Create an OAuth 2.0 credential of type "Web application".
# 4. Add the redirect URI below to the authorized redirect URIs.
# 5. Set YOUTUBE_REDIRECT_URI to match exactly.
# 6. Visit the app, go to Settings → YouTube Accounts → Add account.
#    You'll be redirected to Google to grant the youtube.upload scope.
#    The refresh token is stored automatically — no manual copy needed.
#
# See docs/youtube-oauth.md for the full walkthrough.

YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Max upload size in MB (also configurable in the dashboard Settings tab)
UPLOAD_MAX_SIZE_MB=2048

# Mock mode skips real YouTube uploads and returns fake video IDs.
# Default: false (live mode). Set to "true" only for local dev without OAuth.
YOUTUBE_MOCK_MODE=false
